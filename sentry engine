alias check_sentinel='tail -n 10 ~/sentinel-stack/forensic_history.log | ollama run sentinel-v2'

# The Master Status Report
alias sentinel_report='echo "🛡️ SENTINEL STATUS"; csrutil status; pgrep -f sentry.py'

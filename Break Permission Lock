import pandas as pd

# Load the data we just started collecting
try:
    df = pd.read_csv('~/sentinel-stack/network_log.csv')
    df['timestamp'] = pd.to_datetime(df['timestamp'])

    # Sort to ensure chronological order
    df = df.sort_values(by=['interface', 'timestamp'])

    # Calculate how long each 'NEW_TUNNEL' lasted before 'CLEANUP'
    df['duration'] = df.groupby('interface')['timestamp'].diff()

    print("--- ML Feature Preview ---")
    print(df.tail(10))
    
    # Export for training
    df.to_csv('~/sentinel-stack/processed_features.csv', index=False)
except Exception as e:
    print(f"Waiting for more data... Error: {e}")


import subprocess
import time

LOG_FILE = "/Users/alexiscano/sentinel-stack/network_log.csv"

def get_tunnel_info():
    try:
        output = subprocess.check_output(["netstat", "-ni"]).decode()
        return set([line.split()[0] for line in output.split('\n') if 'utun' in line])
    except:
        return set()

def log_event(label, interface):
    timestamp = time.strftime("%Y-%m-%d %H:%M:%S")
    with open(LOG_FILE, "a") as f:
        f.write(f"{timestamp},{label},{interface}\n")
    print(f"Logged {label} on {interface}")

last_tunnels = get_tunnel_info()
print("ML Data Collection: Recording Baseline...")

while True:
    current_tunnels = get_tunnel_info()
    for t in (current_tunnels - last_tunnels):
        log_event("NEW_TUNNEL", t)
    for t in (last_tunnels - current_tunnels):
        log_event("CLEANUP", t)
    last_tunnels = current_tunnels
    time.sleep(10)
EOF

# 2. Force move it into the sentinel-stack folder
